<%= content_for :page_title, t(".title") %>
<%= content_for :page_actions do %>
  <%= render DS::Link.new(
    text: t(".new"),
    variant: "primary",
    icon: "plus",
    href: new_sale_path
  ) %>
<% end %>

<div data-controller="pending-sales" data-pending-sales-target="container" class="hidden bg-container rounded-xl shadow-border-xs p-4 mb-4">
  <h3 class="text-sm font-medium text-secondary uppercase tracking-wide mb-2">Ventas pendientes de sincronizar</h3>
  <div data-pending-sales-target="list"></div>
</div>

<div class="bg-container rounded-xl shadow-border-xs p-4">
  <% if @sales.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider"><%= t(".columns.sale_number") %></th>
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider"><%= t(".columns.client_name") %></th>
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider"><%= t(".columns.status") %></th>
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider text-right"><%= t(".columns.total") %></th>
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider text-center"><%= t(".columns.currency") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @sales.each do |sale| %>
            <tr class="hover:bg-gray-50/50 cursor-pointer" data-controller="row-click" data-row-click-url-value="<%= sale_path(sale) %>" data-action="click->row-click#visit">
              <td class="px-4 py-3 text-sm text-primary font-medium">
                #<%= sale.sale_number %>
              </td>
              <td class="px-4 py-3 text-sm text-secondary">
                <%= sale.client_name.presence || "-" %>
              </td>
              <td class="px-4 py-3 text-sm">
                <% if sale.draft? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                    <%= t("sales.status.draft") %>
                  </span>
                <% elsif sale.completed? %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                    <%= t("sales.status.completed") %>
                  </span>
                <% else %>
                  <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                    <%= t("sales.status.cancelled") %>
                  </span>
                <% end %>
              </td>
              <td class="px-4 py-3 text-sm text-primary text-right">
                <%= number_to_currency(sale.total, unit: "", separator: ",", delimiter: ".") %>
              </td>
              <td class="px-4 py-3 text-sm text-secondary text-center uppercase">
                <%= sale.currency %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="flex justify-center items-center py-20">
      <div class="text-center flex flex-col items-center max-w-[500px]">
        <p class="text-sm text-secondary mb-4"><%= t(".empty") %></p>
        <div class="flex items-center gap-2">
          <%= render DS::Link.new(
            text: t(".new"),
            variant: "outline",
            icon: "plus",
            href: new_sale_path
          ) %>
        </div>
      </div>
    </div>
  <% end %>
</div>
