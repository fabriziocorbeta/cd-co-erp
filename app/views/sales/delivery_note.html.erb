<% content_for :title do %>
  <%= t(".document_title") %> #<%= @sale.sale_number %>
<% end %>

<div class="max-w-2xl mx-auto text-gray-900">
  <header class="flex justify-between items-start pb-4 border-b-2 border-gray-900">
    <h1 class="text-xl font-bold uppercase tracking-wide"><%= brand_name %></h1>
    <div class="text-right text-sm">
      <p class="font-semibold"><%= t(".title") %> #<%= @sale.sale_number %></p>
      <p class="text-gray-500"><%= @sale.created_at.strftime("%d/%m/%Y") %></p>
    </div>
  </header>

  <div class="grid grid-cols-2 gap-8 py-6 border-b border-gray-100">
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1"><%= t(".client") %></h3>
      <p class="text-sm font-medium"><%= @sale.client_name.presence || "-" %></p>
      <p class="text-sm text-gray-700 whitespace-pre-line mt-1"><%= @sale.delivery_address.presence || "-" %></p>
    </div>
    <div class="text-right">
      <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1"><%= t(".delivery_date") %></h3>
      <p class="text-sm"><%= @sale.delivery_date&.strftime("%d/%m/%Y") || "-" %></p>
      <h3 class="text-xs font-semibold uppercase tracking-wide text-gray-500 mb-1 mt-3"><%= t(".carrier") %></h3>
      <p class="text-sm"><%= @sale.carrier.presence || "-" %></p>
    </div>
  </div>

  <table class="w-full text-sm my-6">
    <thead>
      <tr class="border-t-2 border-b border-gray-900">
        <th class="text-left py-2 text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t(".product") %></th>
        <th class="text-right py-2 text-xs font-semibold uppercase tracking-wide text-gray-500"><%= t(".quantity") %></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-100">
      <% @sale.sale_items.each do |item| %>
        <tr>
          <td class="py-2"><%= item.product.name %></td>
          <td class="py-2 text-right"><%= item.quantity %></td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <footer class="text-center text-xs text-gray-400 pt-8 border-t border-gray-100">
    <p><%= t(".footer_thanks") %></p>
    <p class="font-medium text-gray-600 mt-1"><%= brand_name %></p>
    <p><%= t(".generated_on", date: Time.current.strftime("%d/%m/%Y")) %></p>
  </footer>
</div>
