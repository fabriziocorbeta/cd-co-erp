<%# locals: (purchase_order:) %>

<%= styled_form_with model: purchase_order, class: "space-y-6" do |f| %>
  <% if purchase_order.errors.any? %>
    <%= render "shared/form_errors", model: purchase_order %>
  <% end %>

  <div class="space-y-4">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= f.text_field :supplier_name, label: t(".supplier_name"), autofocus: true %>
      <%= f.select :currency, PurchaseOrder.currencies.keys.map { |k| [k.upcase, k] }, label: t(".currency") %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%= f.date_field :expected_date, label: t(".expected_date") %>
    </div>

    <%= f.text_area :notes, label: t(".notes"), rows: 2 %>
  </div>

  <div class="space-y-4">
    <h3 class="text-lg font-medium text-primary border-b border-gray-100 pb-2"><%= t(".items") %></h3>

    <div class="space-y-3">
      <% if !purchase_order.draft? && purchase_order.persisted? %>
        <%# Read-only items for non-draft purchase orders %>
        <% purchase_order.purchase_order_items.each do |item| %>
          <div class="flex flex-wrap md:flex-nowrap gap-4 p-3 rounded-lg border border-secondary bg-gray-50/50">
            <div class="w-full md:flex-1">
              <label class="text-xs font-medium text-secondary uppercase tracking-wide block mb-1"><%= t(".product") %></label>
              <div class="text-sm text-primary py-1.5"><%= item.product&.name %></div>
            </div>
            <div class="flex-1 md:flex-none md:w-32">
              <label class="text-xs font-medium text-secondary uppercase tracking-wide block mb-1"><%= t(".quantity") %></label>
              <div class="text-sm text-primary py-1.5"><%= item.quantity %></div>
            </div>
            <div class="flex-1 md:flex-none md:w-32">
              <label class="text-xs font-medium text-secondary uppercase tracking-wide block mb-1"><%= t(".unit_cost") %></label>
              <div class="text-sm text-primary py-1.5"><%= number_to_currency(item.unit_cost, unit: "", separator: ",", delimiter: ".") %></div>
            </div>
          </div>
        <% end %>
      <% else %>
        <%# Editable items for new/draft purchase orders %>
        <p class="text-xs text-secondary mb-4"><%= t(".items_help") %></p>

        <%= f.fields_for :purchase_order_items do |item_form| %>
          <%# Only show non-destroyed or new items %>
          <% unless item_form.object.marked_for_destruction? %>
            <div class="flex flex-wrap md:flex-nowrap items-end gap-2 p-3 rounded-lg border border-secondary bg-container" data-controller="element-removal">
              <div class="w-full md:flex-1 md:w-auto min-w-0">
                <%= item_form.label :product_id, t(".product"), class: "text-xs font-medium text-secondary uppercase tracking-wide block mb-1" %>
                <%= item_form.collection_select :product_id, Current.family.products.order(:name), :id, :name, { include_blank: t(".select_product") }, { class: "form-field__input border border-secondary rounded-md px-2.5 py-1.5 w-full text-sm text-primary bg-container" } %>
              </div>
              <div class="flex-1 md:flex-none md:w-28">
                <%= item_form.label :quantity, t(".quantity"), class: "text-xs font-medium text-secondary uppercase tracking-wide block mb-1" %>
                <%= item_form.number_field :quantity, min: 1, class: "form-field__input border border-secondary rounded-md px-2.5 py-1.5 w-full text-sm text-primary bg-container" %>
              </div>
              <div class="flex-1 md:flex-none md:w-32">
                <%= item_form.label :unit_cost, t(".unit_cost"), class: "text-xs font-medium text-secondary uppercase tracking-wide block mb-1" %>
                <%= item_form.number_field :unit_cost, step: 0.01, min: 0, class: "form-field__input border border-secondary rounded-md px-2.5 py-1.5 w-full text-sm text-primary bg-container" %>
              </div>
              <div class="w-8 h-8 flex items-center justify-center shrink-0 mb-[2px]">
                <% if item_form.object.persisted? %>
                  <label class="cursor-pointer text-secondary hover:text-destructive transition-colors w-full h-full flex items-center justify-center" title="Remove item">
                    <%= item_form.check_box :_destroy, class: "hidden", data: { action: "change->element-removal#remove" } %>
                    <%= icon "trash-2", size: "sm", color: "current" %>
                  </label>
                <% else %>
                  <button type="button" class="text-secondary hover:text-destructive transition-colors w-full h-full flex items-center justify-center" data-action="click->element-removal#remove" title="Remove item">
                    <%= icon "trash-2", size: "sm", color: "current" %>
                  </button>
                <% end %>
              </div>
            </div>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

  <div class="flex justify-end gap-2 pt-4">
    <%= render DS::Link.new(
      text: t(".cancel"),
      href: (purchase_order.persisted? ? purchase_order_path(purchase_order) : purchase_orders_path),
      variant: "ghost"
    ) %>
    <%= f.submit t(".submit") %>
  </div>
<% end %>
