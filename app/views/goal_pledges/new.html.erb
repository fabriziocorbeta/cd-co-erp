<%= content_for :page_title, t(".title") %>

<div class="bg-container rounded-xl shadow-border-xs p-6 max-w-lg mx-auto">
  <p class="text-sm text-secondary mb-4"><%= t(".subtitle", name: @goal.name) %></p>

  <%= styled_form_with model: @pledge, url: goal_pledges_path(@goal), class: "space-y-4" do |f| %>
    <% if @pledge.errors.any? %>
      <%= render "shared/form_errors", model: @pledge %>
    <% end %>

    <% if @goal.linked_accounts.size > 1 %>
      <%= f.select :account_id, @goal.linked_accounts.map { |a| [ a.name, a.id ] }, { label: t(".account"), selected: @pledge.account_id }, { class: "form-field__input" } %>
    <% else %>
      <%= f.hidden_field :account_id, value: @pledge.account&.id %>
    <% end %>

    <%= f.number_field :amount, label: t(".amount"), step: :any, required: true, autofocus: true %>

    <div class="flex justify-end gap-2 pt-4">
      <%= render DS::Link.new(text: t(".cancel"), href: goal_path(@goal), variant: "ghost") %>
      <%= f.submit t(".submit") %>
    </div>
  <% end %>
</div>
