<%# locals: (fleet_vehicle:) %>

<%= styled_form_with model: fleet_vehicle, class: "space-y-4" do |f| %>
  <% if fleet_vehicle.errors.any? %>
    <%= render "shared/form_errors", model: fleet_vehicle %>
  <% end %>

  <div class="space-y-4">
    <%= f.text_field :plate, label: t("fleet_vehicles.index.columns.plate"), required: true, autofocus: true %>

    <div class="grid grid-cols-2 gap-4">
      <%= f.text_field :brand, label: t("fleet_vehicles.index.columns.brand"), required: true %>
      <%= f.text_field :model, label: t("fleet_vehicles.index.columns.model"), required: true %>
    </div>

    <div class="grid grid-cols-2 gap-4">
      <%= f.number_field :year, label: t("fleet_vehicles.index.columns.year"), step: 1 %>
      <%= f.select :status, options_for_select(FleetVehicle.statuses.keys.map { |s| [t("fleet_vehicles.statuses.#{s}").capitalize, s] }, fleet_vehicle.status || "active"), label: t("fleet_vehicles.index.columns.status") %>
    </div>

    <%= f.text_area :notes, label: t("fleet_vehicles.notes"), rows: 3 %>
  </div>

  <div class="flex justify-end gap-2 pt-4">
    <%= render DS::Link.new(
      text: t("fleet_vehicles.form.cancel"),
      href: (fleet_vehicle.persisted? ? fleet_vehicle_path(fleet_vehicle) : fleet_vehicles_path),
      variant: "ghost"
    ) %>
    <%= f.submit t("fleet_vehicles.form.submit") %>
  </div>
<% end %>
