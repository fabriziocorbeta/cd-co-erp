<%= content_for :page_title, t("fleet_vehicles.index.title") %>
<%= content_for :page_actions do %>
  <%= render DS::Link.new(
    text: t("fleet_vehicles.index.new"),
    variant: "primary",
    icon: "plus",
    href: new_fleet_vehicle_path
  ) %>
<% end %>

<div class="bg-container rounded-xl shadow-border-xs p-4">
  <% if @fleet_vehicles.any? %>
    <div class="overflow-x-auto">
      <table class="w-full text-left">
        <thead>
          <tr class="border-b border-gray-100">
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider"><%= t("fleet_vehicles.index.columns.plate") %></th>
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider"><%= t("fleet_vehicles.index.columns.brand") %></th>
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider"><%= t("fleet_vehicles.index.columns.model") %></th>
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider"><%= t("fleet_vehicles.index.columns.year") %></th>
            <th class="px-4 py-3 text-xs font-medium text-secondary uppercase tracking-wider"><%= t("fleet_vehicles.index.columns.status") %></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @fleet_vehicles.each do |vehicle| %>
            <tr class="hover:bg-gray-50/50 cursor-pointer" data-controller="row-click" data-row-click-url-value="<%= fleet_vehicle_path(vehicle) %>" data-action="click->row-click#visit">
              <td class="px-4 py-3 text-sm text-primary font-medium">
                <%= vehicle.plate %>
              </td>
              <td class="px-4 py-3 text-sm text-secondary">
                <%= vehicle.brand %>
              </td>
              <td class="px-4 py-3 text-sm text-secondary">
                <%= vehicle.model %>
              </td>
              <td class="px-4 py-3 text-sm text-secondary">
                <%= vehicle.year.presence || "-" %>
              </td>
              <td class="px-4 py-3 text-sm text-secondary capitalize">
                <%= t("fleet_vehicles.statuses.#{vehicle.status}") %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="flex justify-center items-center py-20">
      <div class="text-center flex flex-col items-center max-w-[500px]">
        <p class="text-sm text-secondary mb-4"><%= t("fleet_vehicles.index.empty") %></p>
        <div class="flex items-center gap-2">
          <%= render DS::Link.new(
            text: t("fleet_vehicles.index.new"),
            variant: "outline",
            icon: "plus",
            href: new_fleet_vehicle_path
          ) %>
        </div>
      </div>
    </div>
  <% end %>
</div>
