<%= content_for :page_title, @goal.name %>
<%= content_for :page_actions do %>
  <%= render DS::Menu.new do |menu| %>
    <% menu.with_item(
      variant: "button",
      text: t(".delete"),
      href: goal_path(@goal),
      method: :delete,
      icon: "trash-2",
      confirm: t(".confirm_delete")
    ) %>
  <% end %>

  <% case @goal.display_status %>
  <% when :active %>
    <%= render DS::Button.new(text: t(".pause"), variant: "ghost", icon: "pause", href: pause_goal_path(@goal), method: :patch) %>
    <%= render DS::Button.new(text: t(".complete"), variant: "primary", icon: "check", href: complete_goal_path(@goal), method: :patch, confirm: t(".confirm_complete")) %>
  <% when :paused %>
    <%= render DS::Button.new(text: t(".resume"), variant: "primary", icon: "play", href: resume_goal_path(@goal), method: :patch) %>
  <% when :completed %>
    <%= render DS::Button.new(text: t(".reopen"), variant: "ghost", icon: "rotate-ccw", href: reopen_goal_path(@goal), method: :patch) %>
  <% when :archived %>
    <%= render DS::Button.new(text: t(".unarchive"), variant: "ghost", icon: "archive-restore", href: unarchive_goal_path(@goal), method: :patch) %>
  <% end %>

  <% unless @goal.archived? %>
    <%= render DS::Button.new(text: t(".archive"), variant: "ghost", icon: "archive", href: archive_goal_path(@goal), method: :patch, confirm: t(".confirm_archive")) %>
  <% end %>

  <%= render DS::Link.new(text: t(".edit"), variant: "outline", icon: "pen", href: edit_goal_path(@goal)) %>
<% end %>

<div class="space-y-6">
  <div class="grid grid-cols-1 lg:grid-cols-[320px_minmax(0,1fr)] gap-3">
    <div class="bg-container rounded-xl shadow-border-xs p-5 flex flex-col items-center justify-center text-center">
      <%= render Goals::ProgressRingComponent.new(goal: @goal, size: 180) %>
      <p class="text-xl font-medium text-primary tabular-nums privacy-sensitive mt-4"><%= @goal.current_balance_money.format(precision: 0) %></p>

      <% unless @goal.completed? %>
        <p class="text-xs text-subdued tabular-nums mt-0.5 privacy-sensitive"><%= t(".ring.to_go", amount: @goal.remaining_amount_money.format(precision: 0)) %></p>
      <% end %>
    </div>

    <div class="bg-container rounded-xl shadow-border-xs p-5 flex flex-col">
      <div class="flex flex-col gap-2 mb-2 sm:flex-row sm:items-start sm:justify-between sm:gap-3">
        <div class="min-w-0">
          <h2 class="text-sm font-medium text-primary"><%= t(".projection.heading", default: "Projection") %></h2>
        </div>
      </div>

      <%
        # Determine values to plot for the time series chart
        data_points = []
        if @goal.current_balance.to_d > 0
          data_points << { date: @goal.created_at.strftime("%Y-%m-%d"), value: 0 }
          data_points << { date: Date.today.strftime("%Y-%m-%d"), value: @goal.current_balance.to_f, trend: { color: @goal.color || "#6471eb", current: @goal.current_balance_money.format, value: @goal.current_balance.to_f, previous: { amount: 0 }, percent_formatted: "100%" } }
        end
        series = {
          trend: { color: @goal.color || "#6471eb" },
          values: data_points
        }
      %>
      <div class="flex-1 min-h-[200px]"
           data-controller="time-series-chart"
           data-time-series-chart-data-value="<%= series.to_json %>">
      </div>
    </div>
  </div>

  <% if @goal.linked_accounts.any? %>
    <section class="bg-container rounded-xl shadow-border-xs p-5">
      <%= render Goals::FundingAccountsBreakdownComponent.new(goal: @goal) %>
    </section>
  <% end %>

  <% if @goal.notes.present? %>
    <section class="bg-container rounded-xl shadow-border-xs p-5">
      <h2 class="text-sm font-medium text-primary mb-2"><%= t(".notes") %></h2>
      <p class="text-sm text-secondary whitespace-pre-line"><%= @goal.notes %></p>
    </section>
  <% end %>

  <div>
    <div class="flex justify-between items-center mb-3">
      <h2 class="text-lg font-medium text-primary"><%= t(".pledges") %></h2>
      <% unless @goal.archived? || @goal.completed? %>
        <%= render DS::Link.new(text: t(".add_pledge"), variant: "outline", icon: "plus", href: new_goal_pledge_path(@goal)) %>
      <% end %>
    </div>
    <div class="bg-container rounded-xl shadow-border-xs p-4">
      <% if @open_pledges.any? %>
        <div class="space-y-2">
          <% @open_pledges.each do |pledge| %>
            <div class="flex justify-between items-center py-2 border-b border-gray-100 last:border-0">
              <div>
                <span class="text-sm text-primary font-medium"><%= pledge.amount_money.format(precision: 0) %></span>
                <span class="text-xs text-secondary ml-2"><%= t(".days_left", count: pledge.days_left) %></span>
              </div>
              <div class="flex gap-2">
                <%= render DS::Button.new(text: t(".renew"), variant: "ghost", size: "sm", href: renew_goal_pledge_path(@goal, pledge), method: :patch) %>
                <%= render DS::Button.new(text: t(".cancel_pledge"), variant: "ghost", size: "sm", href: goal_pledge_path(@goal, pledge), method: :delete, confirm: t(".confirm_cancel_pledge")) %>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-secondary text-center py-4"><%= t(".no_pledges") %></p>
      <% end %>
    </div>
  </div>
</div>
