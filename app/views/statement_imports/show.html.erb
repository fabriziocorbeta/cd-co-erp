<div class="container mx-auto py-8">
  <h1 class="text-2xl font-bold mb-2">Revisión del extracto</h1>
  <p class="text-gray-500 mb-6">Banco: <%= @import.bank_name %></p>

  <% if @import.processing? || @import.pending? %>
    <div class="text-center py-12">
      <p class="text-lg">Procesando extracto...</p>
      <meta http-equiv="refresh" content="3">
    </div>

  <% elsif @import.review? %>
    <p class="mb-4 text-sm text-gray-600"><%= @import.parsed_count %> transacciones encontradas</p>

    <div class="overflow-x-auto mb-6">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b bg-gray-50">
            <th class="text-left py-2 px-3">Fecha</th>
            <th class="text-left py-2 px-3">Descripción</th>
            <th class="text-right py-2 px-3">Monto (Gs.)</th>
            <th class="text-right py-2 px-3">Tipo</th>
          </tr>
        </thead>
        <tbody>
          <% @transactions.each do |t| %>
            <tr class="border-b hover:bg-gray-50">
              <td class="py-2 px-3"><%= t.date&.strftime("%d/%m/%Y") %></td>
              <td class="py-2 px-3"><%= t.description %></td>
              <td class="py-2 px-3 text-right font-mono <%= t.debit? ? 'text-red-600' : 'text-green-600' %>">
                <%= number_with_delimiter(t.amount_cents.abs / 100) %>
              </td>
              <td class="py-2 px-3 text-right"><%= t.debit? ? "Débito" : "Crédito" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="flex gap-4">
      <%= form_with url: confirm_statement_import_path(@import), method: :post do |f| %>
        <%= f.hidden_field :account_id, value: Current.family.accounts.first&.id %>
        <%= f.submit "Importar #{@import.parsed_count} transacciones", class: "btn btn-primary" %>
      <% end %>

      <%= button_to "Descartar", reject_statement_import_path(@import),
            method: :post, class: "btn btn-ghost" %>
    </div>

  <% elsif @import.failed? %>
    <div class="bg-red-50 border border-red-200 rounded p-4">
      <p class="text-red-700">Error: <%= @import.error_message %></p>
      <%= link_to "Intentar de nuevo", new_statement_import_path, class: "btn btn-primary mt-3" %>
    </div>

  <% elsif @import.completed? %>
    <div class="bg-green-50 border border-green-200 rounded p-4">
      <p class="text-green-700"><%= @import.imported_count %> transacciones importadas correctamente.</p>
    </div>
  <% end %>
</div>
