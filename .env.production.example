# FinancePY — Variables de producción
# Copiar a .env y completar:  cp .env.production.example .env

# Generar con: openssl rand -hex 64
SECRET_KEY_BASE=

# Postgres
POSTGRES_USER=financespy
# Generar con: openssl rand -hex 32
POSTGRES_PASSWORD=
POSTGRES_DB=financespy_production

# Dominio
APP_DOMAIN=finance.cd-co.com.py

# AI statement parser (Claude)
ANTHROPIC_API_KEY=

# Opcional — chat AI de Sure (incurre costos)
OPENAI_ACCESS_TOKEN=
