# FinancePY — Variables de producción
# Copiar a .env y completar:  cp .env.production.example .env

# Generar con: openssl rand -hex 64
SECRET_KEY_BASE=

# Supabase Postgres — proyecto existente "CD Finanzas", schema separado `financespy`
# 1. SQL Editor en Supabase:  create schema if not exists financespy;
# 2. Dashboard → Connect → Session pooler (IPv4, puerto 5432)
# 3. Agregar al final:  ?schema_search_path=financespy,extensions,public
# Formato: postgresql://postgres.XXXX:PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres?schema_search_path=financespy,extensions,public
DATABASE_URL=

# Dominio
APP_DOMAIN=finance.cd-co.com.py

# AI statement parser (Claude)
ANTHROPIC_API_KEY=

# Opcional — chat AI de Sure (incurre costos)
OPENAI_ACCESS_TOKEN=
