# FinancePY — Variables de producción
# Copiar a .env y completar:  cp .env.production.example .env

# Generar con: openssl rand -hex 64
SECRET_KEY_BASE=

# Supabase Postgres — usar "Session pooler" (IPv4, puerto 5432)
# Supabase dashboard → Project Settings → Database → Connection string
# Formato: postgresql://postgres.XXXX:PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Dominio
APP_DOMAIN=finance.cd-co.com.py

# AI statement parser (Claude)
ANTHROPIC_API_KEY=

# Opcional — chat AI de Sure (incurre costos)
OPENAI_ACCESS_TOKEN=
